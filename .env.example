# Hotel Search Application Environment Variables

# Flask Configuration
SECRET_KEY=your-secret-key-here
FLASK_DEBUG=True

# Database (defaults to SQLite for development)
# DATABASE_URL=sqlite:///./data/hotel.db

# Redis (leave empty for development, no Redis needed)
# REDIS_URL=redis://localhost:6379/0

# RollingGo CLI Configuration (Global Hotel Search)
AIGOHOTEL_API_KEY=your-rollinggo-api-key-here
ROLLINGGO_TIMEOUT=60

# Tuniu MCP Configuration (Domestic Hotel Search & Booking)
TUNIU_API_KEY=your-tuniu-api-key-here
TUNIU_MCP_URL=https://openapi.tuniu.cn/mcp/hotel
TUNIU_TIMEOUT=60

# Default Provider: 'rollinggo' or 'tuniu'
DEFAULT_PROVIDER=tuniu

# Cache Configuration
CACHE_ENABLED=True
CACHE_TTL=3600

# Application Settings
RESULTS_PER_PAGE=20
MAX_FAVORITES=50
MAX_HISTORY=20
