# Production Environment Variables
# Copy this file to .env.production and fill in real values

# Flask Configuration
SECRET_KEY=generate-a-random-64-char-string
FLASK_DEBUG=False

# PostgreSQL Database (set via docker-compose environment)
DATABASE_URL=postgresql://hotel_user:${POSTGRES_PASSWORD}@postgres:5432/hotel_db

# Redis (set via docker-compose environment)
REDIS_URL=redis://redis:6379/0

# PostgreSQL password (used by docker-compose)
POSTGRES_PASSWORD=change-me-to-a-strong-random-password

# RollingGo CLI Configuration
AIGOHOTEL_API_KEY=your-rollinggo-api-key
ROLLINGGO_TIMEOUT=60

# Tuniu MCP Configuration
TUNIU_API_KEY=your-tuniu-api-key
TUNIU_MCP_URL=https://openapi.tuniu.cn/mcp/hotel
TUNIU_TIMEOUT=60

# Default Provider
DEFAULT_PROVIDER=tuniu

# Cache Configuration
CACHE_ENABLED=True
CACHE_TTL=3600

# External Search APIs
SERPER_API_KEY=your-serper-api-key
SERPER_ENABLED=True
TAVILY_API_KEY=your-tavily-api-key
TAVILY_ENABLED=True

# Application Settings
RESULTS_PER_PAGE=20
MAX_FAVORITES=50
MAX_HISTORY=20

# Admin API
ADMIN_PASSWORD=your-admin-password
