# Production Environment Variables
# Copy this file to .env.production and fill in real values

# Flask Configuration
SECRET_KEY=generate-a-random-64-char-string
FLASK_DEBUG=False

# RollingGo CLI Configuration
AIGOHOTEL_API_KEY=your-rollinggo-api-key
ROLLINGGO_TIMEOUT=60

# Tuniu MCP Configuration
TUNIU_API_KEY=your-tuniu-api-key
TUNIU_MCP_URL=https://openapi.tuniu.cn/mcp/hotel
TUNIU_TIMEOUT=60

# Default Provider
DEFAULT_PROVIDER=tuniu

# Cache Configuration
CACHE_ENABLED=True
CACHE_TTL=3600

# External Search APIs
SERPER_API_KEY=your-serper-api-key
SERPER_ENABLED=True
TAVILY_API_KEY=your-tavily-api-key
TAVILY_ENABLED=True

# Application Settings
DATABASE_PATH=./data/hotel.db
RESULTS_PER_PAGE=20
MAX_FAVORITES=50
MAX_HISTORY=20
